{
  "name": "agentops",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Local-first, workflow-driven AI coding agent orchestration platform",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm -r build",
    "lint": "eslint packages/*/src/",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx}\"",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "service:start": "pm2 start ecosystem.config.cjs",
    "service:stop": "pm2 stop agentops",
    "service:restart": "pm2 restart agentops",
    "service:status": "pm2 show agentops",
    "service:logs": "pm2 logs agentops --lines 100"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  }
}
